[
  {
    "rule_id": "cognis-0001-encoded-powershell",
    "name": "Encoded PowerShell Command Execution",
    "type": "query",
    "language": "kuery",
    "query": "process.name : \"powershell.exe\" and process.args : (\"-enc\" or \"-EncodedCommand\" or \"-e\")",
    "risk_score": 73,
    "severity": "high",
    "tags": ["Domain: Endpoint", "Tactic: Defense Evasion", "Technique: T1027"]
  },
  {
    "rule_id": "cognis-0002-failed-logon-burst",
    "name": "Burst of Failed Authentication From Single Source",
    "type": "threshold",
    "language": "kuery",
    "query": "event.category : \"authentication\" and event.outcome : \"failure\"",
    "threshold": {"field": ["source.ip"], "value": 25},
    "risk_score": 47,
    "severity": "medium",
    "tags": ["Domain: Identity", "Tactic: Credential Access"]
  },
  {
    "rule_id": "cognis-0010-rare-dns-tunnel",
    "name": "Anomalous DNS Query Volume to Rare Domain",
    "type": "query",
    "language": "kuery",
    "query": "event.category : \"network\" and dns.question.type : \"TXT\"",
    "risk_score": 55,
    "severity": "medium",
    "tags": ["Domain: Network", "Tactic: Exfiltration", "Technique: T1048"]
  }
]

[
  {
    "rule_id": "cognis-demo-04-failed-logon-burst",
    "name": "Burst of Failed Authentication From Single Source",
    "type": "threshold",
    "language": "kuery",
    "query": "event.category : \"authentication\" and event.outcome : \"failure\"",
    "threshold": {"field": ["source.ip"], "value": 15},
    "risk_score": 60,
    "severity": "high",
    "tags": ["Domain: Identity", "Tactic: Credential Access"]
  },
  {
    "rule_id": "cognis-demo-04-encoded-powershell",
    "name": "Encoded PowerShell Command Execution",
    "type": "query",
    "language": "kuery",
    "query": "process.name : \"powershell.exe\" and process.args : (\"-enc\" or \"-EncodedCommand\")",
    "risk_score": 73,
    "severity": "high",
    "tags": ["Domain: Endpoint", "Tactic: Defense Evasion"]
  },
  {
    "rule_id": "cognis-demo-04-impossible-travel",
    "name": "Successful Logon From Two Distant Geographies",
    "type": "new_terms",
    "language": "kuery",
    "query": "event.category : \"authentication\" and event.outcome : \"success\"",
    "new_terms_fields": ["source.geo.country_iso_code"],
    "risk_score": 55,
    "severity": "medium",
    "tags": ["Domain: Identity", "Tactic: Initial Access"]
  }
]
